<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
	android:id="@+id/card_dhikr"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="@color/btn_action_dark"
    app:cardElevation="4dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Nama Dzikir -->
        <TextView
            android:id="@+id/tv_dhikr_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/text_white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/ibtn_favorite" />

        <!-- Count -->
        <TextView
            android:id="@+id/tv_dhikr_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_white_dim"
            android:textSize="13sp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tv_dhikr_name"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Target -->
        <TextView
            android:id="@+id/tv_dhikr_target"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_white_dim"
            android:textSize="13sp"
            android:layout_marginStart="12dp"
            app:layout_constraintTop_toTopOf="@id/tv_dhikr_count"
            app:layout_constraintStart_toEndOf="@id/tv_dhikr_count" />

        <!-- Tanggal -->
        <TextView
            android:id="@+id/tv_dhikr_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/text_white_dim"
            android:textSize="11sp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tv_dhikr_count"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Tombol Favorit -->
        <ImageButton
            android:id="@+id/ibtn_favorite"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_star_outline"
            android:tint="@color/colorAccent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/ibtn_edit" />

        <!-- Tombol Edit -->
        <ImageButton
            android:id="@+id/ibtn_edit"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_edit"
            android:tint="@color/text_white_dim"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/ibtn_load" />

        <!-- Tombol Load -->
        <ImageButton
            android:id="@+id/ibtn_load"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_target"
            android:tint="@color/text_white_dim"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/ibtn_delete" />

        <!-- Tombol Hapus -->
        <ImageButton
            android:id="@+id/ibtn_delete"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_delete"
            android:tint="@color/colorAccent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>