<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardPrayer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp"
        android:gravity="center_vertical">

        <!-- Nama Sholat -->
        <TextView
            android:id="@+id/tvPrayerName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Badge Berikutnya -->
        <TextView
            android:id="@+id/tvNextBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_badge_next"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="Berikutnya"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:visibility="gone" />

        <!-- Jam -->
        <TextView
            android:id="@+id/tvPrayerTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Icon Alarm Toggle -->
        <ImageButton
            android:id="@+id/btnAlarm"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Toggle alarm"
            android:src="@drawable/ic_alarm_on" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>