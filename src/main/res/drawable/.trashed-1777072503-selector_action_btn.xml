<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/btn_action_pressed" />
            <corners android:radius="@dimen/action_btn_corner" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/btn_action_dark" />
            <corners android:radius="@dimen/action_btn_corner" />
        </shape>
    </item>

</selector>
